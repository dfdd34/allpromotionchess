wss.on("connection", (ws) => {
  send(ws, { type: "connected" });

  ws.on("message", (message) => {
    let data;
    try {
      data = JSON.parse(message.toString());
    } catch {
      return;
    }

    if (data.type === "create_room") {
      createOrJoinRoom(ws, "");
    }

    if (data.type === "join_room") {
      createOrJoinRoom(ws, data.roomId);
    }
  });
});
